# Google Cloud Project ID (from https://console.cloud.google.com)
GOOGLE_CLOUD_PROJECT=your-project-id

# Google Cloud Region (us-central1 is default)
GOOGLE_CLOUD_LOCATION=us-central1

# Path to Service Account Key JSON (download from Cloud Console → IAM → Service Accounts → Keys)
# The service account needs "Vertex AI User" role
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json
